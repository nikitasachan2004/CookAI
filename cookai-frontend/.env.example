# CookAI Frontend Environment Variables
# Copy this file to .env and update the values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000

# Optional: OpenAI API Key for AI Chat (if implementing direct frontend calls)
# VITE_OPENAI_API_KEY=your_openai_api_key_here

# Optional: Analytics and Tracking
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: Feature Flags
# VITE_ENABLE_AI_CHAT=true
# VITE_ENABLE_VOICE_INPUT=false
# VITE_ENABLE_IMAGE_UPLOAD=false

# Optional: Third-party Services
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# VITE_FIREBASE_CONFIG='{"apiKey":"xxx"}'

# Development Settings
# VITE_DEBUG_MODE=true
# VITE_MOCK_API=false